# Environment Variables for Production
# Copy this file to .env and update with real values

# ==============================================
# Database Configuration
# ==============================================
DB_PASSWORD=change_this_to_secure_password
POSTGRES_USER=postgres
POSTGRES_DB=cholon_db

# ==============================================
# PgAdmin (Optional - for database management)
# ==============================================
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin123

# ==============================================
# JWT Configuration
# ==============================================
JWT_SECRET=MySecretKeyForJWTTokenGeneration2026VerySecure!@#$
JWT_EXPIRATION=604800000

# ==============================================
# CORS - Allowed Origins
# ==============================================
# Add your domain here
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173,http://192.168.1.100

# ==============================================
# Spring Profile
# ==============================================
SPRING_PROFILES_ACTIVE=prod
