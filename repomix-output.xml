# =====================================================
# Docker Compose - Production Deployment
# Ubuntu Server with Nginx + Docker
# i5 Gen 12 + 16GB RAM
# =====================================================

services:
  # ===========================================
  # NGINX - Reverse Proxy & Static Files
  # ===========================================
  nginx:
    image: nginx:alpine
    container_name: hanhchinhcong-nginx
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/conf.d:/etc/nginx/conf.d:ro
      # Client (Zalo Mini App) không cần serve - Zalo host
      - ./AdminStaff/dist:/usr/share/nginx/html/admin:ro
      - ./nginx/ssl:/etc/nginx/ssl:ro
      - ./nginx/logs:/var/log/nginx
    depends_on:
      - backend
    networks:
      - hanhchinhcong-network
    restart: unless-stopped
    # Resource limits
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: '0.5'
        reservations:
          memory: 64M

  # ===========================================
  # BACKEND - Spring Boot API
  # ===========================================
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: hanhchinhcong-backend
    ports:
      - "8081:8081"
    environment:
      - SPRING_PROFILES_ACTIVE=prod
      - SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/cholon_db
      - SPRING_DATASOURCE_USERNAME=postgres
      - SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD:-secret}
      - JAVA_OPTS=-Xms1g -Xmx3g -XX:+UseG1GC -XX:MaxGCPauseMillis=200
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - hanhchinhcong-network
    restart: unless-stopped
    healthcheck:
      test: [ "CMD", "curl", "-f", "http://localhost:8081/actuator/health" ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    # Resource limits - Tăng vì Zalo Mini App không tốn RAM server
    deploy:
      resources:
        limits:
          memory: 4096M # 4GB max
          cpus: '3.0'
        reservations:
          memory: 1536M # 1.5GB reserved

  # ===========================================
  # POSTGRESQL - Database
  # ===========================================
  postgres:
    image: postgres:16-alpine
    container_name: hanhchinhcong-postgres
    ports:
      - "5432:5432"
    environment:
      - POSTGRES_DB=cholon_db
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=${DB_PASSWORD:-secret}
      - PGDATA=/var/lib/postgresql/data/pgdata
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./config/postgresql.conf:/etc/postgresql/postgresql.conf:ro
      - ./backups/database:/backups
    command: postgres -c config_file=/etc/postgresql/postgresql.conf
    networks:
      - hanhchinhcong-network
    restart: unless-stopped
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U postgres -d cholon_db" ]
      interval: 10s
      timeout: 5s
      retries: 5
    # Resource limits
    deploy:
      resources:
        limits:
          memory: 4096M # 4GB max
          cpus: '2.0'
        reservations:
          memory: 2048M # 2GB reserved

  # ===========================================
  # PGADMIN - Database Management (Optional)
  # ===========================================
  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: hanhchinhcong-pgadmin
    ports:
      - "5050:80"
    environment:
      - PGADMIN_DEFAULT_EMAIL=${PGADMIN_EMAIL:-admin@local.dev}
      - PGADMIN_DEFAULT_PASSWORD=${PGADMIN_PASSWORD:-admin123}
    volumes:
      - pgadmin_data:/var/lib/pgadmin
    networks:
      - hanhchinhcong-network
    restart: unless-stopped
    profiles:
      - tools # Only start with: docker compose --profile tools up
    deploy:
      resources:
        limits:
          memory: 512M
          cpus: '0.5'

# ===========================================
# NETWORKS
# ===========================================
networks:
  hanhchinhcong-network:
    driver: bridge

# ===========================================
# VOLUMES
# ===========================================
volumes:
  postgres_data:
    driver: local
  pgadmin_data:
    driver: local
</file>

