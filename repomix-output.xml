package com.example.demo.controller;

import com.example.demo.dto.response.ApiResponse;
import com.example.demo.entity.Staff;
import com.example.demo.repository.StaffRepository;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.http.ResponseEntity;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.web.bind.annotation.*;

import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

/**
 * DevToolController - Công cụ dành cho dev/setup
 * KHÔNG cần JWT, KHÔNG cần phân quyền
 *
 * POST /api/dev/reset-password       → đổi mật khẩu 1 tài khoản
 * POST /api/dev/reset-all-passwords  → đặt tất cả cùng 1 mật khẩu
 * GET  /api/dev/list-accounts        → liệt kê tài khoản
 * POST /api/dev/check-password       → kiểm tra password đúng không
 */
@RestController
@RequestMapping("/api/dev")
@RequiredArgsConstructor
@Slf4j
public class DevToolController {

    private final StaffRepository staffRepository;
    private final PasswordEncoder passwordEncoder;

    /**
     * Đặt lại mật khẩu cho 1 tài khoản
     * POST /api/dev/reset-password
     * Body: { "staffCode": "ADMIN", "newPassword": "admin123" }
     */
    @PostMapping("/reset-password")
    public ResponseEntity<ApiResponse<Map<String, Object>>> resetPassword(
            @RequestBody Map<String, String> body) {

        String staffCode = body.get("staffCode");
        String newPassword = body.get("newPassword");

        if (staffCode == null || staffCode.isBlank())
            return ResponseEntity.badRequest()
                    .body(ApiResponse.error("INVALID", "staffCode không được để trống"));
        if (newPassword == null || newPassword.length() < 4)
            return ResponseEntity.badRequest()
                    .body(ApiResponse.error("INVALID", "newPassword phải ít nhất 4 ký tự"));

        Staff staff = staffRepository.findByStaffCode(staffCode).orElse(null);
        if (staff == null)
            return ResponseEntity.badRequest()
                    .body(ApiResponse.error("NOT_FOUND", "Không tìm thấy tài khoản: " + staffCode));

        staff.setPasswordHash(passwordEncoder.encode(newPassword));
        staffRepository.save(staff);
        log.info("[DEV] Reset password -> staffCode={}", staffCode);

        return ResponseEntity.ok(ApiResponse.success(Map.of(
                "staffCode", staffCode,
                "fullName", staff.getFullName(),
                "message", "OK - Đã đặt lại mật khẩu"
        )));
    }

    /**
     * Đặt lại mật khẩu cho TẤT CẢ tài khoản
     * POST /api/dev/reset-all-passwords
     * Body: { "newPassword": "123456" }
     */
    @PostMapping("/reset-all-passwords")
    public ResponseEntity<ApiResponse<Map<String, Object>>> resetAllPasswords(
            @RequestBody Map<String, String> body) {

        String newPassword = body.get("newPassword");
        if (newPassword == null || newPassword.length() < 4)
            return ResponseEntity.badRequest()
                    .body(ApiResponse.error("INVALID", "newPassword phải ít nhất 4 ký tự"));

        List<Staff> all = staffRepository.findAll();
        String hash = passwordEncoder.encode(newPassword);
        all.forEach(s -> s.setPasswordHash(hash));
        staffRepository.saveAll(all);

        log.info("[DEV] Reset ALL {} accounts password", all.size());

        return ResponseEntity.ok(ApiResponse.success(Map.of(
                "updatedCount", all.size(),
                "accounts", all.stream().map(Staff::getStaffCode).collect(Collectors.toList()),
                "message", "Đã đổi mật khẩu cho " + all.size() + " tài khoản"
        )));
    }

    /**
     * Liệt kê tất cả tài khoản
     * GET /api/dev/list-accounts
     */
    @GetMapping("/list-accounts")
    public ResponseEntity<ApiResponse<List<Map<String, Object>>>> listAccounts() {
        List<Staff> all = staffRepository.findAll();
        List<Map<String, Object>> result = all.stream()
                .map(s -> Map.<String, Object>of(
                        "staffCode", s.getStaffCode(),
                        "fullName", s.getFullName(),
                        "role", s.getRole() != null ? s.getRole().getRoleName() : "?",
                        "isActive", Boolean.TRUE.equals(s.getIsActive())
                ))
                .collect(Collectors.toList());
        return ResponseEntity.ok(ApiResponse.success(result));
    }

    /**
     * Kiểm tra password đúng không
     * POST /api/dev/check-password
     * Body: { "staffCode": "ADMIN", "password": "admin123" }
     */
    @PostMapping("/check-password")
    public ResponseEntity<ApiResponse<Map<String, Object>>> checkPassword(
            @RequestBody Map<String, String> body) {

        String staffCode = body.get("staffCode");
        String password = body.get("password");

        Staff staff = staffRepository.findByStaffCode(staffCode).orElse(null);
        if (staff == null)
            return ResponseEntity.badRequest()
                    .body(ApiResponse.error("NOT_FOUND", "Không tìm thấy: " + staffCode));

        boolean matches = passwordEncoder.matches(password, staff.getPasswordHash());
        return ResponseEntity.ok(ApiResponse.success(Map.of(
                "staffCode", staffCode,
                "passwordMatches", matches,
                "hashPrefix", staff.getPasswordHash().substring(0, 20) + "..."
        )));
    }
}
