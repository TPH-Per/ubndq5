    private String citizenName;

    @Column(name = "citizen_phone", length = 15)
    private String citizenPhone;

    @Column(name = "citizen_email", length = 100)
    private String citizenEmail;

    // ===== Zalo (chỉ dùng để gửi thông báo) =====
